<%= render LayoutComponent.new(title: "作業中　作家リスト：全て | 青空文庫") do -%>
<div id="app" class="container mx-auto max-w-5xl py-4">
  <span id="top" name="top">&nbsp;</span>

  <header class="flex items-center justify-between">
    <a href="/" class="md:hidden flex justify-between px-2">
    <img src="/images/top_logo.png" alt="Logo" class="h-8 w-8">
  </a>
    <span class="hidden md:flex">&nbsp;</span>
    <nav class="flex justify-end">
      <div class="md:flex justify-end py-3 hidden">
        <div class="px-2">
          ●
          <a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline"
             href="/index.html">トップ</a>
        </div>
        <div class="px-2">
          ●
          <a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline"
             href="/index_pages/index_top.html">インデックス</a>
        </div>
        <div class="px-2">
          ●作家リスト
        </div>
      </div>

      <div class="flex md:hidden items-center space-x-3 py-3 px-3">
            <button class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline">[メニュー]</button>
      </div>
    </nav>
  </header>

  <h1 class="flex justify-center py-3 text-2xl font-semibold bg-yellow-100 border border-y-gray-500">作業中　作家リスト：全て</h1>

  <div class="text-right py-4">
    <a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="#sec1">[ア]</a>
    <a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="#sec2">[イ]</a>
    <a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="#sec3">[ウ]</a>
    <a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="#sec4">[エ]</a>
    <a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="#sec5">[オ]</a>
  </div>

  <div>
    <p>→<a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="/index_pages/list_inp_person_all.zip">「作業中　作家別作品一覧：全て(CSV形式、zip圧縮）」をダウンロード</a></p>
    <p>→<a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="/index_pages/list_inp_person_all_utf8.zip">「作業中　作家別作品一覧：全て(CSV形式、UTF-8、zip圧縮）」をダウンロード</a></p>
  </div>

  <% authors.keys.each do |kana| %>

  <h2 class="flex py-1 px-5 text-2xl font-semibold bg-gray-300 border border-y-gray-500"><a name="sec1"><%= kana %></a></h2>

  <div class="px-12 py-5">
    <ol class="list-decimal">
      <% authors[kana].each do |person| %>
      <li><a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="list_inp<%= person.id %>_1.html"><%= person.name %></a>　(作業中：<%= person.works.unpublished.count %>)　　<% if person.copyright_flag? %><strong>＊著作権存続＊</strong>　<% end %></li>
      <% end %>
    </ol>
  </div>

  <div class="text-right py-4">
    <a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="#top">▲</a>
  </div>

  <% end %>

  <hr class="border-gray-400">

  <footer class="pt-3 pb-14">
    <div>
      <span class="pr-3">●作家リスト：作業中</span>
      <span><a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="person_inp_a.html">[あ]</a></span>
      <span><a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="person_inp_ka.html">[か]</a></span>
      <span><a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="person_inp_sa.html">[さ]</a></span>
      <span><a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="person_inp_ta.html">[た]</a></span>
      <span><a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="person_inp_na.html">[な]</a></span>
      <span><a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="person_inp_ha.html">[は]</a></span>
      <span><a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="person_inp_ma.html">[ま]</a></span>
      <span><a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="person_inp_ya.html">[や]</a></span>
      <span><a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="person_inp_ra.html">[ら]</a></span>
      <span><a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="person_inp_wa.html">[わ]</a></span>
      <span><a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="person_inp_zz.html">[他]</a></span>
    </div>
    <div>
      <span class="pr-3">
        ●
        <a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="/index.html">トップ</a>
      </span>
      <span class="pr-3">
        ●
        <a class="text-blue-700 hover:text-gray-100 hover:bg-blue-700 visited:text-purple-600 underline" href="/index_pages/index_top.html">インデックス</a>
      </span>
    </div>
  </footer>
</div>
<%- end -%>
